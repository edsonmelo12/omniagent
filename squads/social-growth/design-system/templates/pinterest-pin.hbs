<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} · {{brand}}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@500;700;800&family=Playfair+Display:wght@700;800&display=swap');
    {{tokensCss}}
    {{styleCss}}

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh;
      font-family: var(--style-body-font);
      color: var(--style-text-body);
      padding: 40px;
      background: #efece6;
    }

    .pin-frame {
      width: 330px;
      height: 495px;
      position: relative;
      overflow: hidden;
      background: var(--style-bg);
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    }

    .slide {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
      position: relative;
      isolation: isolate;
      background: var(--style-gradient);
      padding: 40px 32px;
    }

    .slide::before {
      content: "";
      position: absolute; inset: 0; z-index: 0;
      opacity: var(--style-noise-opacity);
      background-image:
        radial-gradient(circle at 22% 18%, rgba(255,255,255,0.9) 0 1px, transparent 1px),
        radial-gradient(circle at 75% 54%, rgba(255,255,255,0.72) 0 1px, transparent 1px);
      background-size: 13px 13px, 19px 19px;
      pointer-events: none;
    }

    .slide::after {
      content: "";
      position: absolute; inset: 0; z-index: 0;
      background: radial-gradient(circle at center, transparent 28%, rgba(0,0,0,var(--style-vignette-opacity)) 100%);
      pointer-events: none;
    }

    .brand-mark {
      position: absolute; top: 16px; left: 20px; z-index: 3;
      color: var(--style-text-muted);
      font-size: 8px;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .brand-mark .accent-dot {
      display: inline-block;
      width: 6px; height: 6px;
      background: var(--style-accent);
      border-radius: 50%;
      margin-right: 4px;
    }

    .content-creative {
      position: relative; z-index: 2;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 12px;
      text-align: center;
    }

    .eyebrow {
      display: inline-flex; align-items: center; width: fit-content;
      color: var(--style-accent);
      background: var(--style-accent-soft);
      border: 1px solid var(--style-border);
      border-radius: 999px;
      padding: 4px 8px;
      font-size: 8px;
      font-weight: 800;
      letter-spacing: 1.2px;
      text-transform: uppercase;
    }

    .title {
      color: var(--style-text-heading);
      font-family: var(--style-heading-font);
      font-size: 22px;
      font-weight: 800;
      line-height: 1.05;
    }

    .body-text {
      color: var(--style-text-body);
      font-size: 11px;
      font-weight: 600;
      line-height: 1.4;
      max-width: 260px;
    }

    .divider {
      width: 36px; height: 2px;
      background: var(--style-accent);
    }

    .cta-block {
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid var(--style-border);
      color: var(--style-text-heading);
      background: linear-gradient(135deg, var(--style-accent-soft), rgba(255,255,255,0.04));
      font-size: 9px;
      font-weight: 800;
    }

    .footer-note {
      position: absolute; bottom: 14px; right: 20px; z-index: 3;
      color: var(--style-text-muted);
      font-size: 7px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      opacity: 0.4;
    }

    body.export-mode {
      background: var(--style-bg); padding: 0;
    }

    body.export-mode .pin-frame {
      width: 1000px; height: 1500px;
      border-radius: 0; box-shadow: none;
    }

    body.export-mode .slide {
      width: 1000px; height: 1500px;
      padding: 120px 80px;
    }

    body.export-mode .brand-mark,
    body.export-mode .footer-note { display: none !important; }

    body.export-mode .title { font-size: 52px; }
    body.export-mode .body-text { max-width: 720px; font-size: 26px; }
    body.export-mode .eyebrow { font-size: 18px; padding: 10px 20px; }
    body.export-mode .divider { width: 100px; height: 4px; }
    body.export-mode .cta-block { padding: 16px 28px; font-size: 22px; }
  </style>
</head>
<body>
  <div class="pin-frame">
    <div class="slide" data-text-variant="{{textVariant}}">
      <div class="brand-mark">
        <span class="accent-dot"></span>
        <span>{{brand}}</span>
      </div>
      <div class="content-creative center">
        {{#if eyebrow}}<span class="eyebrow">{{eyebrow}}</span>{{/if}}
        {{#if title}}<h1 class="title">{{title}}</h1>{{/if}}
        {{#if body}}<p class="body-text">{{body}}</p>{{/if}}
        {{#if showDivider}}<div class="divider"></div>{{/if}}
        {{#if ctaText}}<div class="cta-block">{{ctaText}}</div>{{/if}}
      </div>
      <div class="footer-note">{{brand}}</div>
    </div>
  </div>
</body>
</html>
