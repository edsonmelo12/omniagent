<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@500;700;800&family=Playfair+Display:wght@700;800&display=swap');
    {{tokensCss}}
    {{styleCss}}

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      min-height: 100vh;
      background: #f4f1ea;
      color: var(--style-text-body);
      font-family: var(--style-body-font);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .ig-frame {
      width: var(--ds-preview-w);
      background: #fff;
      border-radius: 26px;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
      overflow: hidden;
    }

    .ig-header {
      height: 48px;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 16px;
      color: #151515;
      font: 700 13px/1 var(--style-body-font);
    }

    .avatar {
      width: 28px;
      height: 28px;
      border-radius: 999px;
      background: var(--style-gradient);
      border: 2px solid var(--style-accent);
    }

    .carousel-viewport {
      width: var(--ds-preview-w);
      height: var(--ds-preview-h);
      overflow: hidden;
      background: var(--style-bg);
    }

    .carousel-track {
      height: 100%;
      display: flex;
      transform: translateX(0);
      transition: transform 260ms ease;
    }

    .slide {
      position: relative;
      min-width: var(--ds-preview-w);
      height: var(--ds-preview-h);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      background: var(--style-bg);
      color: var(--style-text-body);
      padding: 0 var(--ds-content-pad-x);
    }

    .slide::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      opacity: var(--style-noise-opacity);
      background-image:
        radial-gradient(circle at 22% 18%, rgba(255, 255, 255, 0.9) 0 1px, transparent 1px),
        radial-gradient(circle at 75% 54%, rgba(255, 255, 255, 0.72) 0 1px, transparent 1px);
      background-size: 13px 13px, 19px 19px;
      pointer-events: none;
    }

    .slide::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      background: radial-gradient(circle at center, transparent 28%, rgba(0, 0, 0, var(--style-vignette-opacity)) 100%);
      pointer-events: none;
    }

    .slide[data-text-variant="dark"] {
      background: var(--style-bg-alt);
    }

    .slide[data-text-variant="dark"] .eyebrow { color: var(--style-highlight); }
    .slide[data-text-variant="dark"] .title,
    .slide[data-text-variant="dark"] .heading { color: #fff; }
    .slide[data-text-variant="dark"] .body-text,
    .slide[data-text-variant="dark"] .subtitle { color: rgba(255,255,255,0.85); }
    .slide[data-text-variant="dark"] .brand-mark { color: var(--style-accent); }
    .slide[data-text-variant="dark"] .deck-label { color: rgba(255,255,255,0.6); }
    .slide[data-text-variant="dark"] .cta-block { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); color: #fff; }
    .slide[data-text-variant="dark"] .divider { background: var(--style-accent); }
    .slide[data-text-variant="dark"] .footer-zone { color: rgba(255,255,255,0.6); }
    .slide[data-text-variant="dark"] .progress-bar { background: rgba(255,255,255,0.15); }
    .slide[data-text-variant="dark"] .progress-bar span { background: var(--style-accent); }

    .header-zone,
    .footer-zone,
    .progress-bar,
    .swipe-arrow,
    .content-creative { position: relative; z-index: 2; }

    .header-zone {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 32px 0;
      color: var(--style-text-muted);
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: var(--ds-font-caption);
      font-weight: 800;
    }

    .brand-mark { color: var(--style-accent); }
    .deck-label { opacity: 0.76; }

    .content-creative {
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: 16px;
      text-align: left;
    }

    .content-creative.center { align-items: center; text-align: center; }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      color: var(--style-accent);
      background: var(--style-accent-soft);
      border: 1px solid var(--style-border);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: var(--ds-font-caption);
      font-weight: 800;
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    h1, h2, p { margin: 0; }
    .title {
      color: var(--style-text-heading);
      font-family: var(--style-heading-font);
      font-size: var(--ds-font-hero);
      font-weight: 800;
      line-height: 0.98;
      letter-spacing: -0.9px;
      text-shadow: var(--ds-shadow-text);
    }

    .heading {
      color: var(--style-text-heading);
      font-family: var(--style-heading-font);
      font-size: var(--ds-font-heading);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.45px;
      text-shadow: var(--ds-shadow-text);
    }

    .body-text,
    .subtitle {
      max-width: 330px;
      color: var(--style-text-body);
      font-size: var(--ds-font-body);
      font-weight: 700;
      line-height: 1.38;
    }

    .divider {
      width: 76px;
      height: 2px;
      background: var(--style-accent);
      box-shadow: 0 0 22px var(--style-accent-soft);
    }

    .proof-card {
      width: 100%;
      padding: 16px;
      border: 1px solid var(--style-border);
      background: var(--style-surface);
      border-radius: var(--ds-radius-lg);
      box-shadow: var(--ds-shadow-soft);
    }

    .cta-block {
      width: fit-content;
      margin-top: 4px;
      padding: 11px 16px;
      border-radius: 999px;
      border: 1px solid var(--style-border);
      color: var(--style-text-heading);
      background: linear-gradient(135deg, var(--style-accent-soft), rgba(255,255,255,0.04));
      font-size: var(--ds-font-caption);
      font-weight: 800;
      letter-spacing: 0.2px;
    }

    .footer-zone {
      position: absolute;
      left: 32px;
      right: 32px;
      bottom: 24px;
      display: flex;
      justify-content: space-between;
      color: var(--style-text-muted);
      font-size: var(--ds-font-caption);
      font-weight: 800;
      letter-spacing: 1.2px;
      text-transform: uppercase;
    }

    .progress-bar {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 4px;
      background: rgba(255,255,255,0.12);
    }

    .progress-bar span {
      display: block;
      height: 100%;
      background: var(--style-accent);
    }

    .swipe-arrow {
      position: absolute;
      right: 24px;
      bottom: 43px;
      color: var(--style-accent);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .ig-dots {
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
    }

    .ig-dots button {
      width: 6px;
      height: 6px;
      border: 0;
      border-radius: 999px;
      background: #c9c9c9;
      padding: 0;
    }

    .ig-dots button.active { background: #1682f3; }

    @media (min-width: 900px) {
      body {
        padding: 0;
        background: #fff;
      }

      .ig-frame {
        display: block;
        width: var(--ds-export-w);
        border-radius: 0;
        box-shadow: none;
      }

      .ig-header,
      .ig-dots,
      .header-zone,
      .deck-label,
      .footer-zone,
      .swipe-arrow,
      .progress-bar { display: none; }

      .carousel-viewport {
        width: var(--ds-export-w);
        height: var(--ds-export-h);
        overflow: hidden;
      }

      .carousel-track {
        width: max-content;
        height: var(--ds-export-h);
        transition: none;
      }

      .slide {
        min-width: var(--ds-export-w);
        width: var(--ds-export-w);
        max-width: var(--ds-export-w);
        height: var(--ds-export-h);
        padding: 0 var(--ds-export-content-pad-x);
        overflow: hidden;
      }

      .slide[data-text-variant="dark"] { background: var(--style-bg-alt); }
      .slide[data-text-variant="light"] { background: var(--style-bg); }

      .title { font-size: var(--ds-export-font-hero); }
      .heading { font-size: var(--ds-export-font-heading); }
      .body-text,
      .subtitle { max-width: 860px; font-size: var(--ds-export-font-body); }
      .eyebrow { font-size: var(--ds-export-font-caption); padding: 16px 28px; }
      .proof-card { padding: 40px; border-radius: 42px; }
      .proof-card p { font-size: 36px; line-height: 1.4; }
      .divider { width: 190px; height: 5px; }
      .cta-block { padding: 26px 38px; font-size: var(--ds-export-font-caption); }
      .content-creative { gap: 32px; }
    }
  </style>
</head>
<body>
  <div class="ig-frame">
    <div class="ig-header"><div class="avatar"></div><span>{{brand}}</span></div>
    <div class="carousel-viewport">
      <div class="carousel-track" id="carouselTrack">
        {{slidesHtml}}
      </div>
    </div>
    <div class="ig-dots" id="carouselDots">{{dotsHtml}}</div>
  </div>
  <script>
    const track = document.getElementById('carouselTrack');
    const dots = [...document.querySelectorAll('#carouselDots button')];
    let current = 0;
    function showSlide(index) {
      current = Math.max(0, Math.min(index, dots.length - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, idx) => dot.classList.toggle('active', idx === current));
    }
    dots.forEach((dot, index) => dot.addEventListener('click', () => showSlide(index)));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowRight') showSlide(current + 1);
      if (event.key === 'ArrowLeft') showSlide(current - 1);
    });
  </script>
</body>
</html>