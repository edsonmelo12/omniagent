<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} · {{brand}}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Playfair+Display:wght@700;800&display=swap');
    {{tokensCss}}
    {{styleCss}}

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      display: flex; flex-direction: column;
      align-items: center; min-height: 100vh;
      font-family: var(--style-body-font);
      color: var(--style-text-body);
      padding: 40px;
      background: #e9e7e2;
    }

    .fb-frame {
      width: 1200px;
      height: 630px;
      position: relative;
      overflow: hidden;
      border-radius: 0;
      background: var(--style-gradient);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    }

    .bg {
      position: absolute; inset: 0; width: 100%; height: 100%;
      z-index: 0;
      object-fit: cover; object-position: center;
      {{bgFilterCss}}
    }

    .overlay {
      position: absolute; inset: 0;
      z-index: 1;
      background: {{bgOverlay}};
    }

    .slide {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: stretch;
      overflow: hidden;
      position: relative;
      background: transparent;
      padding: 44px 48px 42px;
    }

    .slide::before {
      content: "";
      position: absolute; inset: 0; z-index: 3;
      opacity: var(--style-noise-opacity);
      background-image:
        radial-gradient(circle at 22% 18%, rgba(255,255,255,0.9) 0 1px, transparent 1px),
        radial-gradient(circle at 75% 54%, rgba(255,255,255,0.72) 0 1px, transparent 1px);
      background-size: 13px 13px, 19px 19px;
      pointer-events: none;
    }

    .slide::after {
      content: "";
      position: absolute; inset: 0; z-index: 2;
      background: radial-gradient(circle at center, transparent 28%, rgba(0,0,0,var(--style-vignette-opacity)) 100%);
      pointer-events: none;
    }

    .brand-mark {
      position: absolute; top: 16px; left: 24px; z-index: 5;
      display: flex; align-items: center; gap: 8px;
      color: var(--style-text-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-size: 9px;
      font-weight: 800;
    }

    .brand-mark .dot {
      width: 20px; height: 20px; border-radius: 50%;
      background: var(--style-accent);
    }

    .content-creative {
      position: relative; z-index: 4;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 12px;
      text-align: left;
      max-width: 100%;
      height: 100%;
    }

    .top {
      max-width: 38%;
    }

    .eyebrow {
      display: inline-flex; align-items: center; width: fit-content;
      color: var(--style-accent);
      background: var(--style-accent-soft);
      border: 1px solid var(--style-border);
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 1.2px;
      text-transform: uppercase;
    }

    .title {
      color: var(--style-text-heading);
      font-family: var(--style-heading-font);
      font-size: 58px;
      font-weight: 800;
      line-height: 0.92;
      letter-spacing: -0.04em;
      max-width: 11ch;
    }

    .body-text {
      color: var(--style-text-body);
      font-size: 18px;
      font-weight: 600;
      line-height: 1.52;
      max-width: 29ch;
    }

    .feature-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px 12px;
      width: 100%;
      max-width: 70%;
      margin-top: 4px;
    }

    .feature-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 15px;
      font-weight: 700;
      line-height: 1.35;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(4px);
      color: #fff;
    }

    .feature-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--style-accent);
      flex-shrink: 0;
      margin-top: 6px;
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--style-accent) 20%, transparent);
    }

    .bottom-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 20px;
      margin-top: auto;
    }

    .divider {
      width: 120px; height: 4px;
      background: var(--style-accent);
    }

    .cta-block {
      margin-top: 2px;
      padding: 13px 20px;
      border-radius: 999px;
      border: 1px solid var(--style-border);
      color: var(--style-text-heading);
      background: linear-gradient(135deg, var(--style-accent-soft), rgba(255,255,255,0.04));
      font-size: 13px;
      font-weight: 800;
    }

    .footer-note {
      color: var(--style-text-muted);
      font-size: 12px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .footer-note {
      position: absolute; bottom: 14px; right: 24px; z-index: 5;
      color: var(--style-text-muted);
      font-size: 8px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      opacity: 0.5;
    }

    body.export-mode {
      background: var(--style-bg);
      padding: 0;
    }

    body.export-mode .fb-frame {
      width: 1200px; height: 630px;
      border-radius: 0; box-shadow: none;
    }

    body.export-mode .slide {
      width: 1200px; height: 630px;
      padding: 44px 48px 42px;
    }

    body.export-mode .brand-mark,
    body.export-mode .footer-note { display: none !important; }

    body.export-mode .content-creative { gap: 18px; }
    body.export-mode .top { max-width: 38%; }
    body.export-mode .title { font-size: 58px; }
    body.export-mode .body-text { max-width: 29ch; font-size: 18px; }
    body.export-mode .eyebrow { font-size: 12px; padding: 6px 12px; }
    body.export-mode .divider { width: 120px; height: 4px; }
    body.export-mode .cta-block { padding: 13px 20px; font-size: 13px; }
    body.export-mode .feature-list { max-width: 70%; }
    body.export-mode .feature-item { font-size: 15px; }
  </style>
</head>
<body>
  <div class="fb-frame">
    <div class="slide" data-text-variant="{{textVariant}}">
      {{#if bgSrc}}<img class="bg" src="{{bgSrc}}" alt="" />{{/if}}
      {{#if bgSrc}}<div class="overlay"></div>{{/if}}
      <div class="brand-mark">
        <span class="dot"></span>
        <span>{{brand}}</span>
      </div>
      <div class="content-creative {{alignClass}}">
        <div class="top">
          {{#if eyebrow}}<span class="eyebrow">{{eyebrow}}</span>{{/if}}
          {{#if title}}<h1 class="title">{{title}}</h1>{{/if}}
          {{#if body}}<p class="body-text">{{body}}</p>{{/if}}
          {{#if listHtml}}<div class="feature-list">{{listHtml}}</div>{{/if}}
        </div>
        <div class="bottom-row">
          <div>
            {{#if showDivider}}<div class="divider"></div>{{/if}}
            {{#if ctaText}}<div class="cta-block">{{ctaText}}</div>{{/if}}
          </div>
          {{#if footerNote}}<div class="footer-note">{{footerNote}}</div>{{/if}}
        </div>
      </div>
      <div class="footer-note">{{brand}}</div>
    </div>
  </div>
</body>
</html>
